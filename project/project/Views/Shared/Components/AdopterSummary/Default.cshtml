@model int

<style>
    .adopter-btn {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid #dee2e6;
        border-radius: 50px;
        padding: 4px 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        cursor: default;
        text-decoration: none;
    }

    .adopter-btn:hover {
        background: #ffffff;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        border-color: #0dcaf0; 
    }

    .count-circle {
        background: #0dcaf0;
        color: white;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: bold;
    }

    .btn-label {
        font-size: 13px;
        font-weight: 500;
        color: #444;
    }
</style>

<div class="adopter-btn shadow-sm">
    <span class="btn-label">Adopters</span>
    <div class="count-circle">@Model</div>
</div>