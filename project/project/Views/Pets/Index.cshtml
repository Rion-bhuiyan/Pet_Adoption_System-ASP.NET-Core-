@model IEnumerable<project.Models.Pet>
@{
    ViewData["Title"] = "Pet Adoption List";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-3">

        <!-- Header -->
        <div class="card-header d-flex justify-content-between align-items-center text-white py-3"
             style="background: linear-gradient(135deg, #0072ff, #00c6ff);">
            <h3 class="mb-0 fw-bold">Pet Adoption List</h3>
            <a asp-action="Create" class="btn btn-light btn-sm fw-semibold px-4">
                Create New Pet
            </a>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Pet Name</th>
                        <th>Adoption Fee</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@Html.DisplayFor(modelItem => item.PetName)</td>
                            <td>
                                <span class="badge bg-success fs-6 px-3 py-2">
                                    $@item.AdoptionFee.ToString("N2")
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.PetId"
                                   class="btn btn-warning btn-sm px-3 me-1">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.PetId"
                                   class="btn btn-info btn-sm px-3 me-1 text-white">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.PetId"
                                   class="btn btn-danger btn-sm px-3">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div class="card-footer text-center text-muted py-3">
            © 2026 Pet Haven - Because Every Pet Deserves a Happy Ending
        </div>
    </div>
</div>