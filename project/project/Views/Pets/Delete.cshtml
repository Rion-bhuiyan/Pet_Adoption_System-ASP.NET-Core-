@model project.Models.Pet
@{
    ViewData["Title"] = "Delete Pet";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-lg border-0 rounded-3 overflow-hidden">

                <!-- Header -->
                <div class="card-header text-white text-center py-4"
                     style="background: linear-gradient(135deg, #ff4d4d, #cc0000);">
                    <h2 class="mb-0 fw-bold">Delete Pet</h2>
                </div>

                <div class="card-body p-5">
                    <h4 class="text-center mb-4">Are you sure you want to delete this pet?</h4>

                    <div class="card border border-danger mb-4">
                        <div class="card-body">
                            <dl class="row">
                                <dt class="col-sm-4 fw-semibold">Pet Name</dt>
                                <dd class="col-sm-8">@Html.DisplayFor(model => model.PetName)</dd>

                                <dt class="col-sm-4 fw-semibold">Adoption Fee</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-success fs-6 px-3 py-2">
                                        $@Model.AdoptionFee.ToString("N2")
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <div class="text-center">
                        <form asp-action="Delete" class="d-inline">
                            <input type="hidden" asp-for="PetId" />
                            <button type="submit" class="btn btn-danger btn-lg px-5 py-3 me-3">
                                Yes, Delete This Pet
                            </button>
                        </form>

                        <a asp-action="Index" class="btn btn-secondary btn-lg px-5 py-3">
                            Cancel
                        </a>
                    </div>
                </div>

                <!-- Footer -->
                <div class="card-footer text-center text-muted py-3">
                    © 2026 Pet Haven - Because Every Pet Deserves a Happy Ending
                </div>
            </div>
        </div>
    </div>
</div>