@model project.Models.Pet

@{
    ViewData["Title"] = "Create Pet";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                    <h4 class="mb-0 text-uppercase fw-bold">Add New Pet</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="PetName" class="form-control" placeholder="Enter pet name" />
                            <label asp-for="PetName">Pet Name</label>
                            <span asp-validation-for="PetName" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="AdoptionFee" class="form-control" placeholder="0.00" />
                            <label asp-for="AdoptionFee">Adoption Fee ($)</label>
                            <span asp-validation-for="AdoptionFee" class="text-danger"></span>
                        </div>

                        

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">
                                <i class="bi bi-plus-circle me-2"></i>Create Record
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill mt-2">
                                <i class="bi bi-arrow-left me-1"></i>Back to Gallery
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .card {
        transition: all 0.3s ease-in-out;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .btn-primary {
        background: linear-gradient(45deg, #0d6efd, #0043a8);
        border: none;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}